# Dependencies
node_modules/

# Build output
dist/
src-tauri/target/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Logs
*.log

# Test artifacts
test-results/
playwright-report/
playwright/.auth/

# Claude Code local settings
.claude/settings.local.json
# Claude Code runtime artifacts (per-machine sessionId / pid lock files)
.claude/*.lock

# Tauri signing keys
*.key
*.key.pub

# Auto-generated documentation scanner output
docs/project-scan-report.json

# Tauri auto-generated files (schemas/ etc.) — regenerated on every build, per-platform (matches official Tauri template)
src-tauri/gen/

# Git worktrees
.worktrees/

# Test coverage (vitest v8 - pnpm test:coverage)
coverage/

# TypeScript / ESLint caches
*.tsbuildinfo
.eslintcache

# Playwright merged/sharded report (complements test-results/ & playwright-report/)
blob-report/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Visual Studio
.vs/

# Editor backups / merge leftovers
*~
*.bak
*.tmp
*.orig

# Sentry CLI auth (never commit a local auth token)
.sentryclirc
